# Local frontend -> local Worker
VITE_CLOUDFLARE_API_URL=http://localhost:8787
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
VITE_LLM_PROVIDER=openai

# For deployed Pages, set this in Cloudflare Pages environment variables:
# VITE_CLOUDFLARE_API_URL=https://api.syncresume.io
# VITE_CLERK_PUBLISHABLE_KEY=pk_live_your_clerk_publishable_key

# Worker/local `.dev.vars` values for paid backend LLM usage:
# OPENAI_API_KEY=sk-...
# DEFAULT_LLM_PROVIDER=openai
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-5
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.5-flash
# For deployed Workers, set Stripe secrets with `wrangler secret put` or the
# Cloudflare Dashboard secret UI. Do not store live secret values as Worker vars.
# STRIPE_SECRET_KEY=local_test_secret_only
# STRIPE_WEBHOOK_SECRET=local_webhook_secret_only
# STRIPE_PRICE_MONTHLY_ID=price_...
# STRIPE_PRICE_6_MONTH_ID=price_...
# STRIPE_PRICE_YEARLY_ID=price_...
