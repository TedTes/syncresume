---
import MarketingNav from "../components/MarketingNav.astro";
import MarketingFooter from "../components/MarketingFooter.astro";
import MarketingLayout from "../layouts/MarketingLayout.astro";
import { APP_WORKSPACE_URL } from "../lib/urls";

---

<MarketingLayout
  title="Privacy Policy | SyncResume"
  description="Read how SyncResume handles resume content, account information, billing data, and AI processing."
  canonicalPath="/privacy"
>
  <div class="landing">
    <MarketingNav />

    <main class="landing-section landing-legal">
      <div class="landing-container">
        <p class="landing-eyebrow">Privacy</p>
        <h1>Privacy Policy</h1>
        <p class="landing-legal-muted">Effective date: July 13, 2026</p>

        <h2>Information we collect</h2>
        <p>
          SyncResume collects information you provide to use the product, including account details, resume files or pasted resume text, job descriptions, generated resumes, cover letters, and application history.
        </p>

        <h2>How we use information</h2>
        <p>
          We use this information to provide resume tailoring, cover letter generation, resume storage, export features, billing, product support, abuse prevention, and product improvement.
        </p>

        <h2>AI processing</h2>
        <p>
          Resume and job description content may be sent to AI providers to structure resumes, tailor content, revise sections, and generate cover letters. Do not upload information you do not want processed for these product features.
        </p>

        <h2>Service providers</h2>
        <p>
          We use third-party providers for hosting, authentication, payments, storage, analytics, and AI processing. These providers process data only as needed to operate SyncResume.
        </p>

        <h2>Payments</h2>
        <p>
          Payments are processed by Stripe. SyncResume does not store full card numbers. Stripe may collect billing details and payment information according to its own terms and privacy policy.
        </p>

        <h2>Data retention</h2>
        <p>
          We retain account and workspace data while your account is active or as needed to provide the service. You can delete resumes and generated application data from the app where supported.
        </p>

        <h2>Contact</h2>
        <p>
          For privacy questions, contact the SyncResume team through the support channel listed in the product.
        </p>
      </div>
    </main>


    <MarketingFooter />
  </div>
</MarketingLayout>
