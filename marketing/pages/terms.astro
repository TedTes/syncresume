---
import MarketingNav from "../components/MarketingNav.astro";
import MarketingFooter from "../components/MarketingFooter.astro";
import MarketingLayout from "../layouts/MarketingLayout.astro";
import { APP_WORKSPACE_URL } from "../lib/urls";

---

<MarketingLayout
  title="Terms of Service | SyncResume"
  description="Read the terms for using SyncResume's resume tailoring, cover letter, export, billing, and account features."
  canonicalPath="/terms"
>
  <div class="landing">
    <MarketingNav />

    <main class="landing-section landing-legal">
      <div class="landing-container">
        <p class="landing-eyebrow">Terms</p>
        <h1>Terms of Service</h1>
        <p class="landing-legal-muted">Effective date: July 13, 2026</p>

        <h2>Use of SyncResume</h2>
        <p>
          SyncResume helps users tailor resumes, generate cover letters, manage application versions, and export documents. You are responsible for the content you upload, edit, generate, and submit to employers.
        </p>

        <h2>No guarantee of employment</h2>
        <p>
          SyncResume can improve resume workflow and presentation, but it does not guarantee interviews, job offers, salary outcomes, or ATS results.
        </p>

        <h2>Your content</h2>
        <p>
          You retain ownership of the resume, job description, and application content you provide. You grant SyncResume permission to process that content as needed to operate the service.
        </p>

        <h2>Acceptable use</h2>
        <p>
          Do not use SyncResume to upload unlawful content, infringe others' rights, attack the service, bypass usage limits, or generate misleading application materials.
        </p>

        <h2>Subscriptions and billing</h2>
        <p>
          Paid plans renew according to the billing period shown at checkout. You can manage or cancel subscriptions through the billing portal where available. Fees already paid may be non-refundable unless required by law.
        </p>

        <h2>Availability</h2>
        <p>
          We aim to keep SyncResume reliable, but the service may change, pause, or experience downtime. Features may evolve as the product improves.
        </p>

        <h2>Contact</h2>
        <p>
          For terms or billing questions, contact the SyncResume team through the support channel listed in the product.
        </p>
      </div>
    </main>


    <MarketingFooter />
  </div>
</MarketingLayout>
