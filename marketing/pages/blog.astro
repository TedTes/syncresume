---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import { APP_WORKSPACE_URL } from "../lib/urls";

const year = new Date().getFullYear();

const POSTS = [
  {
    category: "ATS guides",
    title: "How ATS systems actually parse your resume — and what breaks them",
    desc: "Most ATS failures aren't from design. They're from tables, columns, and text boxes that cause parsers to drop entire sections.",
    href: "/blog",
    soon: true,
  },
  {
    category: "ATS guides",
    title: "What does your ATS score actually measure?",
    desc: "ATS scores are a keyword match percentage, not a quality rating. Here's how to read them — and what to do when yours is low.",
    href: "/blog",
    soon: true,
  },
  {
    category: "ATS guides",
    title: "The best resume formats for ATS in 2025",
    desc: "Single-column, reverse-chronological, saved as PDF — why this combination clears more parsers than any other layout.",
    href: "/blog",
    soon: true,
  },
  {
    category: "Tailoring",
    title: "Tailoring vs. rewriting: when to customize vs. start fresh",
    desc: "Tailoring adjusts keywords and bullet emphasis. Rewriting repositions your experience for a different role. Knowing which to do saves hours.",
    href: "/blog",
    soon: true,
  },
  {
    category: "Tailoring",
    title: "How to tailor a resume for a job description in under 30 minutes",
    desc: "A repeatable process: extract keywords, scan your bullets, rewrite matches, check the score. No AI required — but it helps.",
    href: "/blog",
    soon: true,
  },
  {
    category: "Cover letters",
    title: "How to write a job-specific cover letter (that isn't generic)",
    desc: "A cover letter that references the exact role, team, and requirements outperforms a polished generic one every time.",
    href: "/blog",
    soon: true,
  },
  {
    category: "Role keywords",
    title: "Resume keywords for software engineers",
    desc: "The skills, tools, and phrases that appear most in software engineering job descriptions — organized by seniority and stack.",
    href: "/blog",
    soon: true,
  },
  {
    category: "Role keywords",
    title: "Resume keywords for product managers",
    desc: "PM job descriptions share a consistent vocabulary. Here are the terms that matter and how to work them into your bullets naturally.",
    href: "/blog",
    soon: true,
  },
  {
    category: "Comparisons",
    title: "Resume tailoring tools compared: SyncResume, Jobscan, Teal, and manual",
    desc: "What each approach does, what it misses, and when the tradeoff is worth it.",
    href: "/blog",
    soon: true,
  },
];
---

<MarketingLayout
  title="Resume Tailoring Guides and ATS Advice | SyncResume Blog"
  description="Guides for tailoring resumes, understanding ATS parsing, writing job-specific cover letters, and choosing resume templates."
  canonicalPath="/blog"
>
  <div class="landing">
    <header class="landing-nav">
      <div class="landing-nav-inner">
        <a class="landing-brand" href="/">
          <div class="landing-brand-mark" aria-hidden="true">
            <svg viewBox="0 0 18 22" fill="none" aria-hidden="true">
              <rect x="2.5" y="1" width="14" height="18.5" rx="2.2" stroke="rgba(255,255,255,0.18)" stroke-width="1.1" transform="rotate(7 9.5 10.25)" />
              <path d="M1.5 3C1.5 2.17 2.17 1.5 3 1.5H11.5L16.5 6.5V19C16.5 19.83 15.83 20.5 15 20.5H3C2.17 20.5 1.5 19.83 1.5 19V3Z" fill="rgba(34,197,94,0.07)" stroke="rgba(255,255,255,0.7)" stroke-width="1.2" />
              <path d="M11.5 1.5L16.5 6.5H13C12.17 6.5 11.5 5.83 11.5 5V1.5Z" fill="#22c55e" />
              <rect x="4" y="9.5" width="9" height="1.5" rx="0.75" fill="rgba(255,255,255,0.55)" />
              <rect x="4" y="12.5" width="5.5" height="1.4" rx="0.7" fill="#22c55e" opacity="0.85" />
              <rect x="4" y="15.5" width="7" height="1.2" rx="0.6" fill="rgba(255,255,255,0.22)" />
            </svg>
          </div>
          <span class="landing-brand-name">SyncResume</span>
        </a>
        <nav class="landing-nav-links" aria-label="Site">
          <a href="/how-it-works">How it works</a>
          <a href="/templates">Templates</a>
          <a href="/pricing">Pricing</a>
        </nav>
        <a class="btn btn-primary btn-sm" href={APP_WORKSPACE_URL}>Start tailoring free</a>
      </div>
    </header>

    <section class="landing-section" style="border-top: none; padding-top: 56px; padding-bottom: 0;">
      <div class="landing-container">
        <p class="landing-eyebrow">Blog</p>
        <h1 style="font-size: clamp(1.4rem, 2.5vw, 1.9rem); font-weight: 700; color: var(--ink); margin: 8px 0 0; letter-spacing: -0.02em; line-height: 1.2;">
          Resume tailoring guides and ATS advice.
        </h1>

        <div class="landing-blog-list">
          {POSTS.map(({ category, title, desc, href, soon }) => (
            <a href={href} class="landing-blog-item" aria-label={title}>
              <span class="landing-blog-tag">{category}</span>
              <div>
                <h2>{title}</h2>
                <p>{desc}</p>
              </div>
              {soon && (
                <span class="landing-blog-soon">Soon</span>
              )}
            </a>
          ))}
        </div>
      </div>
    </section>

    <footer class="landing-footer" style="margin-top: 64px;">
      <div class="landing-container">
        <div class="landing-footer-inner">
          <a class="landing-brand" href="/" aria-label="SyncResume home">
            <div class="landing-brand-mark" aria-hidden="true">
              <svg viewBox="0 0 18 22" fill="none" aria-hidden="true">
                <rect x="2.5" y="1" width="14" height="18.5" rx="2.2" stroke="rgba(255,255,255,0.18)" stroke-width="1.1" transform="rotate(7 9.5 10.25)" />
                <path d="M1.5 3C1.5 2.17 2.17 1.5 3 1.5H11.5L16.5 6.5V19C16.5 19.83 15.83 20.5 15 20.5H3C2.17 20.5 1.5 19.83 1.5 19V3Z" fill="rgba(34,197,94,0.07)" stroke="rgba(255,255,255,0.7)" stroke-width="1.2" />
                <path d="M11.5 1.5L16.5 6.5H13C12.17 6.5 11.5 5.83 11.5 5V1.5Z" fill="#22c55e" />
                <rect x="4" y="9.5" width="9" height="1.5" rx="0.75" fill="rgba(255,255,255,0.55)" />
                <rect x="4" y="12.5" width="5.5" height="1.4" rx="0.7" fill="#22c55e" opacity="0.85" />
                <rect x="4" y="15.5" width="7" height="1.2" rx="0.6" fill="rgba(255,255,255,0.22)" />
              </svg>
            </div>
            <span class="landing-brand-name">SyncResume</span>
          </a>
          <div class="landing-footer-links" aria-label="Footer navigation">
            <a href="/how-it-works">How it works</a>
            <a href="/templates">Templates</a>
            <a href="/pricing">Pricing</a>
            <a href="/blog">Blog</a>
            <a href="/privacy">Privacy</a>
            <a href="/terms">Terms</a>
          </div>
          <p class="landing-footer-copy">© {year} SyncResume</p>
        </div>
      </div>
    </footer>
  </div>
</MarketingLayout>
