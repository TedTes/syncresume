---
import MarketingNav from "../components/MarketingNav.astro";
import MarketingFooter from "../components/MarketingFooter.astro";
import MarketingLayout from "../layouts/MarketingLayout.astro";
import { APP_WORKSPACE_URL } from "../lib/urls";
---

<MarketingLayout
  title="AI Cover Letter Generator — Job-Specific, Not Generic | SyncResume"
  description="SyncResume generates a targeted cover letter alongside every tailored resume — written for the specific role, not a fill-in-the-blank template."
  canonicalPath="/cover-letter-generator"
>
  <div class="landing">

    <MarketingNav />

    <section class="landing-hero">
      <div class="landing-container">
        <div class="landing-hero-content">
          <div class="landing-hero-text">
            <p class="landing-eyebrow">Cover letter generator</p>
            <h1 class="landing-hero-headline">
              A cover letter written<br />for the actual job.
            </h1>
            <p class="landing-hero-sub">
              Every tailored resume comes with a matching cover letter — one that references the specific role, company, and your relevant experience. No generic templates.
            </p>
            <div class="landing-hero-actions">
              <a class="btn btn-primary" href={APP_WORKSPACE_URL}>
                Generate a cover letter
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
              </a>
            </div>
          </div>
          <div aria-hidden="true" style="padding:22px;border:1px solid var(--border);border-radius:14px;background:rgba(24,24,27,0.72);">
            <div style="margin-bottom:12px;font-size:0.68rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:var(--muted);">Cover letter preview</div>
            <div style="display:flex;flex-direction:column;gap:7px;">
              {[92, 78, 100, 65, 88, 55, 94, 72].map(w => (
                <div style={`height:7px;border-radius:4px;background:rgba(255,255,255,0.08);width:${w}%`}></div>
              ))}
              <div style="height:1px;background:rgba(255,255,255,0.06);margin:8px 0;"></div>
              {[85, 70, 100, 60].map(w => (
                <div style={`height:7px;border-radius:4px;background:rgba(255,255,255,0.08);width:${w}%`}></div>
              ))}
              <div style="height:1px;background:rgba(255,255,255,0.06);margin:8px 0;"></div>
              {[75, 90, 55].map(w => (
                <div style={`height:7px;border-radius:4px;background:rgba(34,197,94,0.15);width:${w}%`}></div>
              ))}
            </div>
            <div style="margin-top:14px;display:inline-flex;align-items:center;gap:6px;padding:4px 12px;border-radius:999px;background:rgba(34,197,94,0.1);border:1px solid rgba(34,197,94,0.2);color:#70e7af;font-size:0.72rem;font-weight:700;">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Role-specific
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="landing-section landing-section-alt">
      <div class="landing-container">
        <div class="landing-section-header">
          <p class="landing-eyebrow">What makes it different</p>
          <h2 class="landing-section-title">Not a template. A letter for this job.</h2>
        </div>
        <div class="landing-features">
          {[
            { label: "Role-specific content", desc: "The letter references the exact job title, company name, and requirements from the posting — not placeholder text.", wide: false },
            { label: "Grounded in your resume", desc: "Generated from your actual experience and bullets — no hallucinated credentials or invented achievements.", wide: false },
            { label: "Saved with your application", desc: "Every cover letter is bundled with the tailored resume and job description it was made for, keeping everything organized.", wide: true },
          ].map(({ label, desc, wide }) => (
            <div class={`landing-feature${wide ? " landing-feature--wide" : ""}`}>
              <div class="landing-feature-top">
                <div class="landing-feature-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                    <polyline points="22,6 12,13 2,6"/>
                  </svg>
                </div>
                <h3 class="landing-feature-label">{label}</h3>
              </div>
              <p class="landing-feature-desc">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="landing-final-cta">
      <div class="landing-container">
        <div class="landing-final-cta-card">
          <div>
            <p class="landing-eyebrow">Ready to apply?</p>
            <h2>Get your resume and cover letter in one run.</h2>
          </div>
          <a class="btn btn-primary" href={APP_WORKSPACE_URL}>
            Start now — it's free
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
        </div>
      </div>
    </section>


    <MarketingFooter />
  </div>
</MarketingLayout>
