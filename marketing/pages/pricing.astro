---
import MarketingNav from "../components/MarketingNav.astro";
import MarketingFooter from "../components/MarketingFooter.astro";
import MarketingLayout from "../layouts/MarketingLayout.astro";
import { APP_WORKSPACE_URL } from "../lib/urls";

const PLANS = [
  {
    name: "Free",
    price: "$0",
    cadence: "per month",
    note: "Start tailoring without a card.",
    cta: "Start free",
    featured: false,
    features: [
      "Limited monthly AI credits",
      "Resume tailoring",
      "Cover letter generation",
      "ATS score before & after",
      "Template previews",
      "PDF and DOCX export",
    ],
  },
  {
    name: "Pro Monthly",
    price: "$14",
    cadence: "per month",
    note: "Best when you are actively applying this month.",
    cta: "Upgrade monthly",
    featured: false,
    features: [
      "More monthly AI credits",
      "Saved resume versions",
      "Cover letters for each role",
      "All templates and exports",
      "Cancel anytime through Stripe",
    ],
  },
  {
    name: "Pro 6-Month",
    price: "$49",
    cadence: "every 6 months",
    note: "For a longer search with a lower monthly cost.",
    badge: "Save 42%",
    cta: "Choose 6-month",
    featured: false,
    features: [
      "Everything in Pro Monthly",
      "Better value across a multi-month search",
      "Resume and cover letter history",
      "Template exports for every application",
      "Secure billing portal",
    ],
  },
  {
    name: "Pro Yearly",
    price: "$79",
    cadence: "per year",
    note: "Best value for ongoing career moves.",
    badge: "Best value",
    cta: "Choose yearly",
    featured: true,
    features: [
      "Everything in Pro Monthly",
      "Lowest effective monthly cost",
      "Long-term version history",
      "Template and export access all year",
      "Secure billing portal",
    ],
  },
];
---

<MarketingLayout
  title="Pricing — Free to Start | SyncResume"
  description="SyncResume pricing starts free, with Pro monthly, 6-month, and yearly plans for more resume tailoring credits, cover letters, templates, and exports."
  canonicalPath="/pricing"
>
  <div class="landing">

    <MarketingNav />

    <section class="landing-section" style="border-top: none; padding-top: 80px; padding-bottom: 80px;">
      <div class="landing-container">
        <div class="landing-section-header" style="text-align: center;">
          <p class="landing-eyebrow">Pricing</p>
          <h1 class="landing-section-title" style="font-size: clamp(1.8rem, 3.5vw, 2.6rem);">
            Free to start.<br />Upgrade when you need more credits.
          </h1>
          <p style="color: var(--muted); font-size: 1rem; line-height: 1.65; margin-top: 10px;">
            Try the core workflow first. Pro adds more monthly AI credits, saved versions, cover letters, templates, and exports for a serious search.
          </p>
        </div>

        <div class="landing-pricing-grid">
          {PLANS.map((plan) => (
            <article class={`landing-pricing-card${plan.featured ? " is-featured" : ""}`}>
              <div class="landing-pricing-card-top">
                <div>
                  <h2>{plan.name}</h2>
                  <p>{plan.note}</p>
                </div>
                {plan.badge && <span class="landing-pricing-badge">{plan.badge}</span>}
              </div>
              <div class="landing-pricing-price">
                <span>{plan.price}</span>
                <small>{plan.cadence}</small>
              </div>
              <ul class="landing-pricing-features">
                {plan.features.map((feature) => (
                  <li>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>
              <a class={plan.featured ? "btn btn-primary" : "btn btn-secondary"} href={APP_WORKSPACE_URL}>
                {plan.cta}
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="landing-section landing-section-alt">
      <div class="landing-container">
        <div class="landing-positioning">
          <p class="landing-eyebrow">Transparent plan limits</p>
          <h2>Start free, then upgrade only when the search gets serious.</h2>
          <p>
            Free is designed for trying the workflow. Pro is for repeated applications: more AI credits,
            saved versions, cover letters, template exports, and billing controls through Stripe.
          </p>
        </div>
      </div>
    </section>

    <section class="landing-final-cta">
      <div class="landing-container">
        <div class="landing-final-cta-card">
          <div>
            <p class="landing-eyebrow">Start now</p>
            <h2>Tailor your first resume in under two minutes.</h2>
          </div>
          <a class="btn btn-primary" href={APP_WORKSPACE_URL}>
            Start tailoring free
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
        </div>
      </div>
    </section>


    <MarketingFooter />
  </div>
</MarketingLayout>
