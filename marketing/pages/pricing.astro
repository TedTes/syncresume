---
import MarketingLayout from "../layouts/MarketingLayout.astro";
const year = new Date().getFullYear();

const FREE_FEATURES = [
  "Resume tailoring (up to 5 per month)",
  "Cover letter generation",
  "ATS score before & after",
  "All resume templates",
  "Application bundles",
  "PDF and DOCX export",
];
---

<MarketingLayout
  title="Pricing — Free to Start | SyncResume"
  description="SyncResume is free to start. Tailor resumes, generate cover letters, and export to PDF or DOCX at no cost."
  canonicalPath="/pricing"
>
  <div class="landing">

    <header class="landing-nav">
      <div class="landing-nav-inner">
        <a class="landing-brand" href="/">
          <div class="landing-brand-mark" aria-hidden="true">
            <svg viewBox="0 0 18 22" fill="none" aria-hidden="true">
              <rect x="2.5" y="1" width="14" height="18.5" rx="2.2" stroke="rgba(255,255,255,0.18)" stroke-width="1.1" transform="rotate(7 9.5 10.25)" />
              <path d="M1.5 3C1.5 2.17 2.17 1.5 3 1.5H11.5L16.5 6.5V19C16.5 19.83 15.83 20.5 15 20.5H3C2.17 20.5 1.5 19.83 1.5 19V3Z" fill="rgba(34,197,94,0.07)" stroke="rgba(255,255,255,0.7)" stroke-width="1.2" />
              <path d="M11.5 1.5L16.5 6.5H13C12.17 6.5 11.5 5.83 11.5 5V1.5Z" fill="#22c55e" />
              <rect x="4" y="9.5" width="9" height="1.5" rx="0.75" fill="rgba(255,255,255,0.55)" />
              <rect x="4" y="12.5" width="5.5" height="1.4" rx="0.7" fill="#22c55e" opacity="0.85" />
              <rect x="4" y="15.5" width="7" height="1.2" rx="0.6" fill="rgba(255,255,255,0.22)" />
            </svg>
          </div>
          <span class="landing-brand-name">SyncResume</span>
        </a>
        <nav class="landing-nav-links" aria-label="Site">
          <a href="/how-it-works">How it works</a>
          <a href="/templates">Templates</a>
          <a href="/pricing" aria-current="page">Pricing</a>
        </nav>
        <a class="btn btn-primary btn-sm" href="/app/workspace/optimize">
          Start tailoring free
        </a>
      </div>
    </header>

    <section class="landing-section" style="border-top: none; padding-top: 80px; padding-bottom: 80px;">
      <div class="landing-container">
        <div class="landing-section-header" style="text-align: center;">
          <p class="landing-eyebrow">Pricing</p>
          <h1 class="landing-section-title" style="font-size: clamp(1.8rem, 3.5vw, 2.6rem);">
            Free to start.<br />No credit card required.
          </h1>
          <p style="color: var(--muted); font-size: 1rem; line-height: 1.65; margin-top: 10px;">
            Everything you need to tailor resumes and apply smarter — available for free.
          </p>
        </div>

        <div style="max-width: 420px; margin: 0 auto;">
          <div style="padding: 32px; border: 1px solid rgba(34,197,94,0.4); border-radius: 16px; background: radial-gradient(circle at top right, rgba(34,197,94,0.12), transparent 40%), rgba(24,24,27,0.9);">
            <div style="display:flex; align-items:baseline; gap: 8px; margin-bottom: 6px;">
              <span style="font-size: 3rem; font-weight: 800; color: var(--ink); line-height: 1;">$0</span>
              <span style="font-size: 0.9rem; color: var(--muted);">/ month</span>
            </div>
            <p style="color: var(--muted); font-size: 0.9rem; margin-bottom: 28px;">Free tier — no card needed to get started.</p>
            <div style="display:flex; flex-direction:column; gap: 12px; margin-bottom: 28px;">
              {FREE_FEATURES.map(f => (
                <div style="display:flex; align-items:flex-start; gap: 10px; font-size: 0.9rem; color: var(--ink); line-height: 1.4;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:2px;" aria-hidden="true">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  {f}
                </div>
              ))}
            </div>
            <a class="btn btn-primary" href="/app/workspace/optimize" style="width:100%;justify-content:center;">
              Get started — it's free
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="landing-section landing-section-alt">
      <div class="landing-container">
        <div class="landing-positioning">
          <p class="landing-eyebrow">No paywalls on the core workflow</p>
          <h2>Tailoring, cover letters, export — all free.</h2>
          <p>
            The full tailoring workflow — paste a job description, get a tailored resume and cover letter, download as PDF — is free.
            No feature gates, no watermarks, no credits to track.
          </p>
        </div>
      </div>
    </section>

    <section class="landing-final-cta">
      <div class="landing-container">
        <div class="landing-final-cta-card">
          <div>
            <p class="landing-eyebrow">Start now</p>
            <h2>Tailor your first resume in under two minutes.</h2>
          </div>
          <a class="btn btn-primary" href="/app/workspace/optimize">
            Start tailoring free
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <footer class="landing-footer">
      <div class="landing-container">
        <div class="landing-footer-inner">
          <a class="landing-brand" href="/" aria-label="SyncResume home">
            <div class="landing-brand-mark" aria-hidden="true">
              <svg viewBox="0 0 18 22" fill="none" aria-hidden="true">
                <rect x="2.5" y="1" width="14" height="18.5" rx="2.2" stroke="rgba(255,255,255,0.18)" stroke-width="1.1" transform="rotate(7 9.5 10.25)" />
                <path d="M1.5 3C1.5 2.17 2.17 1.5 3 1.5H11.5L16.5 6.5V19C16.5 19.83 15.83 20.5 15 20.5H3C2.17 20.5 1.5 19.83 1.5 19V3Z" fill="rgba(34,197,94,0.07)" stroke="rgba(255,255,255,0.7)" stroke-width="1.2" />
                <path d="M11.5 1.5L16.5 6.5H13C12.17 6.5 11.5 5.83 11.5 5V1.5Z" fill="#22c55e" />
                <rect x="4" y="9.5" width="9" height="1.5" rx="0.75" fill="rgba(255,255,255,0.55)" />
                <rect x="4" y="12.5" width="5.5" height="1.4" rx="0.7" fill="#22c55e" opacity="0.85" />
                <rect x="4" y="15.5" width="7" height="1.2" rx="0.6" fill="rgba(255,255,255,0.22)" />
              </svg>
            </div>
            <span class="landing-brand-name">SyncResume</span>
          </a>
          <div class="landing-footer-links" aria-label="Footer navigation">
            <a href="/how-it-works">How it works</a>
            <a href="/templates">Templates</a>
            <a href="/pricing">Pricing</a>
            <a href="/blog">Blog</a>
            <a href="/privacy">Privacy</a>
            <a href="/terms">Terms</a>
          </div>
          <p class="landing-footer-copy">© {year} SyncResume</p>
        </div>
      </div>
    </footer>
  </div>
</MarketingLayout>
