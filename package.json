{
  "name": "syncresume",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "dev:app": "vite",
    "dev:marketing": "astro dev",
    "build": "tsc -b && astro build",
    "build:app": "tsc -b && SYNCRESUME_APP_BUILD=1 vite build --outDir dist/app && node scripts/prepare-app-pages-output.mjs",
    "build:marketing": "tsc -b && astro build",
    "preview": "vite preview",
    "cf:types": "WRANGLER_WRITE_LOGS=false wrangler types cloudflare/worker/worker-configuration.d.ts --include-runtime false --env-file cloudflare/typegen.env",
    "cf:types:check": "WRANGLER_WRITE_LOGS=false wrangler types cloudflare/worker/worker-configuration.d.ts --include-runtime false --env-file cloudflare/typegen.env --check",
    "cf:typecheck": "tsc -p tsconfig.worker.json",
    "cf:dev": "WRANGLER_WRITE_LOGS=false wrangler dev --local",
    "cf:deploy": "WRANGLER_WRITE_LOGS=false wrangler deploy --keep-vars",
    "cf:d1:apply:local": "WRANGLER_WRITE_LOGS=false wrangler d1 migrations apply syncresume --local",
    "cf:d1:apply": "WRANGLER_WRITE_LOGS=false wrangler d1 migrations apply syncresume --remote",
    "cf:pages:deploy": "npm run build && WRANGLER_WRITE_LOGS=false wrangler pages deploy dist --project-name syncresume",
    "cf:pages:deploy:app": "VITE_CLOUDFLARE_API_URL=https://api.syncresume.io npm run build:app && WRANGLER_WRITE_LOGS=false wrangler pages deploy dist/app --project-name syncresume-app"
  },
  "dependencies": {
    "@astrojs/react": "^6.0.1",
    "@clerk/clerk-react": "^5.61.8",
    "@cloudflare/puppeteer": "^1.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "docx": "^9.5.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.8.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@cloudflare/workers-types": "^4.20260616.1",
    "@emnapi/core": "^1.11.1",
    "@emnapi/runtime": "^1.11.1",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "astro": "^7.0.7",
    "typescript": "^5.7.2",
    "vite": "^8.0.16",
    "wrangler": "^4.101.0"
  }
}
