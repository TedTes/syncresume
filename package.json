{
  "name": "syncresume",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "cf:types": "WRANGLER_WRITE_LOGS=false wrangler types cloudflare/worker/worker-configuration.d.ts --include-runtime false",
    "cf:types:check": "WRANGLER_WRITE_LOGS=false wrangler types cloudflare/worker/worker-configuration.d.ts --include-runtime false --check",
    "cf:typecheck": "tsc -p tsconfig.worker.json",
    "cf:dev": "WRANGLER_WRITE_LOGS=false wrangler dev --local",
    "cf:deploy": "WRANGLER_WRITE_LOGS=false wrangler deploy",
    "cf:d1:apply:local": "WRANGLER_WRITE_LOGS=false wrangler d1 migrations apply syncresume --local",
    "cf:d1:apply": "WRANGLER_WRITE_LOGS=false wrangler d1 migrations apply syncresume --remote",
    "cf:pages:deploy": "npm run build && WRANGLER_WRITE_LOGS=false wrangler pages deploy dist --project-name syncresume"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.61.8",
    "@vitejs/plugin-react": "^5.0.0",
    "docx": "^9.5.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.8.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260616.1",
    "@emnapi/core": "^1.11.1",
    "@emnapi/runtime": "^1.11.1",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "typescript": "^5.7.2",
    "vite": "^8.0.16",
    "wrangler": "^4.101.0"
  }
}
