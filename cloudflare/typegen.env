# Non-secret placeholders used only by `wrangler types`.
# Runtime values still come from Cloudflare Worker vars/secrets or local `.dev.vars`.
APP_ORIGIN=https://syncresume.io
DEFAULT_LLM_PROVIDER=openai
OPENAI_MODEL=gpt-5.4-mini
OPENAI_API_KEY=typecheck-placeholder
CLERK_JWKS_URL=https://example.com/.well-known/jwks.json
CLERK_ISSUER=https://example.com
CLERK_AUTHORIZED_PARTIES=https://syncresume.io
STRIPE_SECRET_KEY=typecheck-placeholder
STRIPE_WEBHOOK_SECRET=typecheck-placeholder
STRIPE_PRICE_ID=price_typecheck
BILLING_SUCCESS_URL=https://syncresume.io/settings?billing=success
BILLING_CANCEL_URL=https://syncresume.io/settings?billing=cancelled
BILLING_PORTAL_RETURN_URL=https://syncresume.io/settings
